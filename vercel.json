{
  "version": 2,
  "public": true,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/.netlify/functions/send-push",
      "destination": "/api/send-push"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/daily-study-reminder",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/cron/daily-streak-reminder",
      "schedule": "0 22 * * *"
    }
  ]
}
